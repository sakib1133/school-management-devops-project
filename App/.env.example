PORT=3000
NODE_ENV=development

# SQLite database path
# LOCAL DEVELOPMENT (Windows/Linux/Mac): Use a local path
#   Example: ./data/school.db (creates data/ folder in project)
#   Example: ./school.db (creates in project root)
#
# RENDER PRODUCTION: Set in Render Dashboard (not in this file)
#   Value: /var/data/database.sqlite
#   This uses Render's persistent disk at /var/data
#
# If you remove this line, the app will auto-select:
#   - Development: ./data/school.db
#   - Production:  /var/data/database.sqlite
DB_PATH=./data/school.db

# Security secrets - generate strong random values for production
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret
ENCRYPTION_KEY=your_encryption_key

# Email configuration
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Payment gateway credentials
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret

# Database type
DB_URL=sqlite

# Admin initial password (ONLY for first admin creation on fresh database)
# After first startup, admin can change password via profile settings
# If not set and no admin exists, app will warn but continue safely
ADMIN_PASSWORD=your_secure_admin_password_here
