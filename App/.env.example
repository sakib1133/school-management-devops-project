PORT=3000
NODE_ENV=development

# FREE TIER RENDER SETUP:
# The app automatically selects database path based on NODE_ENV:
#   - Development (local): ./school.db
#   - Production (Render):  runtime/database.sqlite (copied from data/school.db)
#
# DO NOT set DB_PATH - the app handles this automatically.
# Just set NODE_ENV=production in Render dashboard.
#
# IMPORTANT: Keep your complete database at data/school.db in the repo.
# On each Render deploy, it will be copied to runtime/ folder automatically.

# Security secrets - generate strong random values for production
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret
ENCRYPTION_KEY=your_encryption_key

# Email configuration
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Payment gateway credentials
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret

# Database type
DB_URL=sqlite

# Admin initial password (ONLY for first admin creation on fresh database)
# After first startup, admin can change password via profile settings
# If not set and no admin exists, app will warn but continue safely
ADMIN_PASSWORD=your_secure_admin_password_here
